# ==========================================
# Arlo Camera Management System
# Environment Configuration Template
# ==========================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env in the same directory
# 2. Fill in all values with your actual credentials
# 3. NEVER commit .env to git (add to .gitignore)
# 4. NEVER share .env file with others
#

# ==========================================
# ARLO ACCOUNT CREDENTIALS
# ==========================================
# Your Arlo account email and password
# These are used to authenticate with Arlo's cloud API

ARLO_EMAIL=your-email@example.com
ARLO_PASSWORD=your-arlo-password

# Optional: Two-factor authentication
# If you have 2FA enabled on your account, you may need to:
# 1. Temporarily disable it for the API to work, OR
# 2. Generate an app-specific password
# See SETUP_GUIDE.md for more details

# ==========================================
# TWILIO SMS CONFIGURATION
# ==========================================
# Used for sending motion detection alerts via SMS
# Get these from https://console.twilio.com

# Your Twilio Account SID (starts with AC)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token (long alphanumeric string)
TWILIO_AUTH_TOKEN=your-auth-token-here

# Your Twilio Phone Number (format: +1234567890)
# This is the number your alerts will come FROM
TWILIO_PHONE_NUMBER=+1234567890

# Your Phone Number (format: +1234567890)
# This is the number where you RECEIVE alerts
# Make sure this number is verified in Twilio!
ALERT_PHONE_NUMBER=+1987654321

# ==========================================
# LOCAL STORAGE CONFIGURATION
# ==========================================
# Where to save downloaded recordings and data

# Local folder path for storing recordings
# Can be relative (./arlo_recordings) or absolute (/mnt/data/arlo)
ARLO_STORAGE_PATH=./arlo_recordings

# ==========================================
# API SERVER CONFIGURATION
# ==========================================
# (Optional - defaults to 0.0.0.0:8000)

API_HOST=0.0.0.0
API_PORT=8000

# ==========================================
# ADVANCED OPTIONS (Optional)
# ==========================================

# Motion detection sensitivity
# Options: high, medium, low
MOTION_SENSITIVITY=high

# Minimum seconds between alert messages
# Prevents spam if motion is continuous
ALERT_COOLDOWN=300

# Enable automatic recording
AUTO_RECORD=true

# Recording duration in seconds
RECORDING_DURATION=30

# ==========================================
# LOGGING CONFIGURATION (Optional)
# ==========================================

LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ==========================================
# NOTES & TROUBLESHOOTING
# ==========================================
#
# 1. ARLO_PASSWORD
#    - If you have 2FA enabled, you may need to disable it temporarily
#    - Or create an app-specific password
#    - Arlo support: https://support.arlo.com
#
# 2. TWILIO CREDENTIALS
#    - Get Account SID: https://console.twilio.com
#    - Auth Token is shown on dashboard (keep secret!)
#    - Trial accounts have $15 credit (~2000 SMS)
#    - Verify phone numbers before use
#
# 3. STORAGE PATH
#    - Ensure the directory exists or is writable
#    - Use absolute paths for reliability in production
#    - Monitor disk space - videos can be large!
#
# 4. TEST YOUR SETUP
#    - Run: python -c "from dotenv import load_dotenv; load_dotenv(); import os; print('✓' if os.getenv('ARLO_EMAIL') else '✗')"
#    - Visit: http://localhost:8000/docs for API docs
#    - Check: http://localhost:3000 for dashboard
#
